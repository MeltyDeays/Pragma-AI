  color: #ffffff;
  padding: 0.75rem 1.5rem;
  border-radius: 10px;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-weight: 700;
  font-size: 0.9rem;
  transition: all 0.25s ease;
  box-shadow: 0 4px 12px rgba(124, 58, 237, 0.3);
}

.btn-new-challenge:hover {
