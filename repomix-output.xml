}

.game-card:hover {
  background: #27272a;
  border-color: rgba(99, 102, 241, 0.4);
  transform: translateY(-4px);
}

.game-card-icon {
  color: var(--color-primary);
  margin-bottom: 0.5rem;
}

.game-card h3 {
  font-size: 1.15rem;
  font-weight: 700;
  margin: 0;
  color: var(--color-text-main);
}

.game-card p {
  font-size: 0.85rem;
  color: var(--color-text-muted);
  margin: 0;
  line-height: 1.4;
}

.game-xp-tag {
  background: rgba(16, 185, 129, 0.1);
  color: #34d399;
  border: 1px solid rgba(16, 185, 129, 0.2);
  padding: 0.25rem 0.6rem;
  font-size: 0.75rem;
  border-radius: 6px;
  font-weight: 700;
  align-self: flex-start;
}

.game-active-container {
  background: #18181b;
  border: 1px solid var(--border-light);
  border-radius: 16px;
  padding: 2rem;
  box-shadow: var(--shadow-main);
}

.game-active-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  padding-bottom: 1rem;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
  gap: 1rem;
}

.btn-back-game {
  background: transparent;
  border: none;
  color: var(--color-text-muted);
  cursor: pointer;
  font-size: 0.9rem;
  font-weight: 500;
  transition: var(--transition-smooth);
}

.btn-back-game:hover {
  color: var(--color-text-main);
}

.game-active-header h2 {
  font-size: 1.35rem;
  margin: 0;
  font-weight: 800;
}

.game-loading {
  text-align: center;
  padding: 3rem 0;
  color: var(--color-text-muted);
}

.game-code-block {
  background: #09090b;
  border: 1px solid var(--border-light);
  border-radius: 10px;
  padding: 1.25rem;
  overflow-x: auto;
  margin: 1rem 0;
  font-family: 'Fira Code', monospace;
  font-size: 0.85rem;
  line-height: 1.5;
  text-align: left;
}

.trivia-game {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.trivia-question {
  font-size: 1.2rem;
  font-weight: 600;
  line-height: 1.4;
  margin: 0;
}

.trivia-options {
  display: flex;
  flex-direction: column;
  gap: 0.85rem;
}

.trivia-option {
  position: relative;
  background: rgba(39, 39, 42, 0.6);
  border: 1px solid rgba(255, 255, 255, 0.08);
  color: var(--color-text-main);
  padding: 1.15rem 1.5rem;
  border-radius: 12px;
  cursor: pointer;
  text-align: left;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  font-family: inherit;
  font-size: 0.95rem;
  outline: none;
  overflow: hidden;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.15);
}

.trivia-option::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.03), transparent);
  transform: translateX(-100%);
  transition: transform 0.5s ease;
}

.trivia-option:hover {
  background: rgba(63, 63, 70, 0.85);
  border-color: rgba(255, 255, 255, 0.2);
  transform: translateY(-2px);
  box-shadow: 0 6px 15px rgba(0, 0, 0, 0.25), 0 0 10px rgba(124, 58, 237, 0.15);
}

.trivia-option:hover::before {
  transform: translateX(100%);
}

.trivia-option.correct {
  background: rgba(16, 185, 129, 0.12) !important;
  border-color: #10b981 !important;
  color: #34d399 !important;
  box-shadow: 0 0 20px rgba(16, 185, 129, 0.35) !important;
  animation: correctBounce 0.4s ease-out;
}

.trivia-option.wrong {
  background: rgba(239, 68, 68, 0.12) !important;
  border-color: #ef4444 !important;
  color: #f87171 !important;
  box-shadow: 0 0 20px rgba(239, 68, 68, 0.35) !important;
  animation: wrongShake 0.4s ease-out;
}

@keyframes correctBounce {
  0% { transform: scale(1); }
  50% { transform: scale(1.04); }
  100% { transform: scale(1); }
}

@keyframes wrongShake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-6px); }
  75% { transform: translateX(6px); }
}

.game-feedback {
  margin-top: 1.75rem;
  padding: 1.5rem;
  border-radius: 12px;
  border: 1px solid;
  font-size: 0.95rem;
  line-height: 1.6;
