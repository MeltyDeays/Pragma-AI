{
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "parsable": true,
    "headerText": "IA-PROFESOR Repository Packaged Context"
  },
  "include": [
    "src/**/*",
    "server.js",
    "database/**/*"
  ],
  "exclude": [
    "node_modules/**",
    ".git/**",
    "dist/**",
    "package-lock.json",
    "repomix-output.xml",
    "temp_clones/**"
  ]
}
